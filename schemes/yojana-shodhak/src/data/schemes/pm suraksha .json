    "policy_type": "Renewable One-Year Personal Accident Insurance Scheme",
    "coverage_period": "1 June to 31 May every year"
  },
  "objective": {
    "primary": "Provide affordable accident insurance coverage to citizens",
    "secondary": [
      "Financial support to families in case of accidental death",
      "Protection against accidental disabilities",
      "Increase insurance penetration among low-income households",
      "Provide social security at a nominal premium"
    ]
  },
  "benefits": {
    "accidental_death_cover": {
      "amount": 200000,
      "currency": "INR"
    },
    "permanent_total_disability_cover": {
      "amount": 200000,
      "currency": "INR"
    },
    "partial_disability_cover": {
      "amount": 100000,
      "currency": "INR"
    },
    "premium": {
      "annual_amount": 20,
      "currency": "INR",
      "payment_mode": "Auto-debit from bank account"
    }
  },
  "eligibility_criteria": {
    "citizenship": {
      "required": true,
      "details": "Indian residents and eligible bank account holders"
    },
    "age": {
      "minimum": 18,
      "maximum": 70,
      "unit": "years"
    },
    "bank_account": {
      "required": true,
      "details": "Must have an active savings bank or post office account"
    },
    "aadhaar": {
      "required": true,
      "details": "Aadhaar is the primary KYC document"
    },
    "multiple_accounts": {
      "allowed": false,
      "note": "Only one PMSBY policy is allowed per individual"
    },
    "medical_examination": {
      "required": false,
      "details": "No medical examination required"
    }
  },
  "documents_required": {
    "mandatory": [
      "Aadhaar Card",
      "Savings Bank Account",
      "Consent for Auto-Debit"
    ],
    "claim_documents": [
      "Claim Form",
      "Death Certificate (for death claims)",
      "Disability Certificate",
      "Hospital Records",
      "FIR/Police Report (if applicable)",
      "Nominee Identity Proof"
    ]
  },
  "enrollment_process": {
    "step_1": "Visit participating bank, post office, net banking or mobile banking portal",
    "step_2": "Submit enrollment form",
    "step_3": "Provide Aadhaar and nominee details",
    "step_4": "Authorize annual premium auto-debit",
    "step_5": "Coverage becomes active after successful enrollment"
  },
  "claim_process": {
    "step_1": "Inform bank/insurance company about accident",
    "step_2": "Submit claim form and supporting documents",
    "step_3": "Verification by bank and insurer",
    "step_4": "Claim approval by insurance company",
    "step_5": "Benefit amount transferred to nominee/insured person"
  },
  "termination_conditions": {
    "coverage_ends_if": [
