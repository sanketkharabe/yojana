      "Bank account is closed",
      "Insufficient balance for premium deduction",
      "Multiple PMSBY accounts detected",
      "Policy voluntarily discontinued"
    ]
  },
  "important_features": {
    "accidental_death_cover": "₹2 Lakh",
    "total_disability_cover": "₹2 Lakh",
